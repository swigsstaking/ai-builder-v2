<footer class="site-footer" data-section="footer">
  <div class="container footer-inner">
    <div class="footer-col">
      {{#if logoUrl}}
        <img src="{{logoUrl}}" alt="{{site.business.name}}" class="footer-logo" width="150" height="50" loading="lazy">
      {{else}}
        <span class="footer-logo-text">{{site.business.name}}</span>
      {{/if}}
      {{#if site.business.address}}
        <p class="footer-address">
          {{site.business.address}}<br>
          {{site.business.zip}} {{site.business.city}}
        </p>
      {{/if}}
    </div>
    <div class="footer-col">
      {{#if site.business.email}}
        <div class="footer-contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:{{site.business.email}}">{{site.business.email}}</a>
        </div>
      {{/if}}
      {{#if site.business.phone}}
        <div class="footer-contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          <a href="tel:{{site.business.phone}}">{{site.business.phone}}</a>
        </div>
      {{/if}}
      <div class="social-links">
        {{#if site.business.socialLinks.facebook}}<a href="{{site.business.socialLinks.facebook}}" target="_blank" rel="noopener" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></a>{{/if}}
        {{#if site.business.socialLinks.instagram}}<a href="{{site.business.socialLinks.instagram}}" target="_blank" rel="noopener" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>{{/if}}
        {{#if site.business.socialLinks.tiktok}}<a href="{{site.business.socialLinks.tiktok}}" target="_blank" rel="noopener" aria-label="TikTok"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.51a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.89a8.28 8.28 0 004.76 1.51V6.95a4.84 4.84 0 01-1-.26z"/></svg></a>{{/if}}
        {{#if site.business.socialLinks.youtube}}<a href="{{site.business.socialLinks.youtube}}" target="_blank" rel="noopener" aria-label="YouTube"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3 3 0 00-2.12-2.12C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.57A3 3 0 00.5 6.19 31.25 31.25 0 000 12a31.25 31.25 0 00.5 5.81 3 3 0 002.12 2.12c1.84.57 9.38.57 9.38.57s7.54 0 9.38-.57a3 3 0 002.12-2.12A31.25 31.25 0 0024 12a31.25 31.25 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg></a>{{/if}}
        {{#if site.business.socialLinks.linkedin}}<a href="{{site.business.socialLinks.linkedin}}" target="_blank" rel="noopener" aria-label="LinkedIn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.47 2H3.53A1.45 1.45 0 002.06 3.43v17.14A1.45 1.45 0 003.53 22h16.94A1.45 1.45 0 0021.94 20.57V3.43A1.45 1.45 0 0020.47 2zM8.09 18.74h-3v-9h3v9zM6.59 8.48a1.56 1.56 0 110-3.12 1.56 1.56 0 010 3.12zM18.91 18.74h-3v-4.26c0-1.08-.43-1.58-1.29-1.58-.93 0-1.42.53-1.42 1.58v4.26h-3v-9h3v1.21a3 3 0 012.63-1.44c1.87 0 3.08 1.14 3.08 3.49v5.74z"/></svg></a>{{/if}}
      </div>
    </div>
    <div class="footer-col">
      <p class="footer-nav-title">Navigation</p>
      <ul class="footer-nav">
        {{#each allPages}}
        <li><a href="{{#if this.isMainHomepage}}index.html{{else}}{{this.slug}}.html{{/if}}">{{this.title}}</a></li>
        {{/each}}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>{{#if site.footer.copyrightText}}{{{site.footer.copyrightText}}}{{else}}&copy; {{year}} {{site.business.name}}. Tous droits r&eacute;serv&eacute;s.{{/if}}
      {{#if showLegalLinks}}
      | <a href="{{#if site.footer.legalPageSlug}}{{site.footer.legalPageSlug}}{{else}}mentions-legales{{/if}}.html">Mentions l&eacute;gales</a>
      | <a href="{{#if site.footer.cgvPageSlug}}{{site.footer.cgvPageSlug}}{{else}}cgv{{/if}}.html">CGV</a>
      {{/if}}
    </p>
  </div>
</footer>
