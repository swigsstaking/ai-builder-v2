<section class="section section-services-grid" data-section="services-grid">
  <div class="container">
    {{#if title}}<h2 class="section-title" data-editable="title">{{title}}</h2>{{/if}}
    {{#if subtitle}}<p class="section-subtitle" data-editable="subtitle">{{subtitle}}</p>{{/if}}
    <div class="services-grid">
      {{#each services}}
        <div class="service-card">
          <div class="service-card-img" data-editable="services.{{@index}}.imageMediaId">
            {{#if this.imageUrl}}
              <img
                src="{{this.imageUrl}}"
                {{#if this.imageMediaId_srcset}}srcset="{{this.imageMediaId_srcset}}"{{/if}}
                sizes="(max-width: 768px) 50vw, 25vw"
                alt="{{this.name}}"
                loading="lazy"
              >
            {{else}}
              <div class="img-placeholder">
                <span style="color:#9ca3af;font-size:0.875rem;">Cliquez pour ajouter une image</span>
              </div>
            {{/if}}
          </div>
          <h3 data-editable="services.{{@index}}.name">{{this.name}}</h3>
          {{#if this.shortDescription}}<p data-editable="services.{{@index}}.shortDescription">{{this.shortDescription}}</p>{{/if}}
          {{#if this.linkUrl}}
            <a href="{{this.linkUrl}}" class="service-card-link">{{this.name}} &rarr;</a>
          {{/if}}
        </div>
      {{/each}}
    </div>
  </div>
</section>
